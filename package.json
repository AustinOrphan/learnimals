{
  "name": "learnimals",
  "version": "1.0.0",
  "description": "Educational web application featuring interactive games and activities for children",
  "type": "module",
  "scripts": {
    "generate-subjects": "node scripts/generateSubjects.js",
    "list-templates": "node scripts/generateSubjects.js --list-templates",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/unit",
    "test:navigation": "vitest run tests/navigation",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "education",
    "children",
    "games",
    "learning"
  ],
  "private": true,
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@vitest/ui": "^3.2.4",
    "eslint": "^8.57.0",
    "happy-dom": "^18.0.1",
    "jsdom": "^24.1.0",
    "vitest": "^3.2.4"
  }
}
