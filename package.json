{
  "name": "learnimals",
  "version": "1.0.0",
  "description": "Educational web application featuring interactive games and activities for children",
  "type": "commonjs",
  "scripts": {
    "generate-subjects": "node scripts/generateSubjects.js",
    "list-templates": "node scripts/generateSubjects.js --list-templates",
    "lint": "eslint src/ scripts/ tests/ --ext .js",
    "lint:fix": "eslint src/ scripts/ tests/ --ext .js --fix",
    "lint:check": "eslint src/ scripts/ tests/ --ext .js --max-warnings 0",
    "format": "prettier --write \"**/*.{js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,css,html}\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --config vitest.config.unit.js",
    "test:components": "vitest run --config vitest.config.components.js",
    "test:integration": "vitest run --config vitest.config.integration.js"
  },
  "keywords": ["education", "children", "games", "learning"],
  "private": true,
  "devDependencies": {
    "eslint": "^8.57.0",
    "@eslint/js": "^8.57.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsdoc": "^48.0.0",
    "eslint-plugin-security": "^2.1.0",
    "eslint-plugin-unicorn": "^51.0.0",
    "eslint-plugin-sonarjs": "^0.23.0",
    "eslint-plugin-promise": "^6.1.0",
    "eslint-plugin-n": "^16.6.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.2.0",
    "vitest": "^2.0.0",
    "jsdom": "^25.0.0",
    "@vitest/ui": "^2.0.0",
    "happy-dom": "^15.0.0"
  }
}