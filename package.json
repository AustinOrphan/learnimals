{
  "name": "learnimals",
  "version": "1.0.0",
  "description": "Educational web application featuring interactive games and activities for children",
  "type": "module",
  "scripts": {
    "generate-subjects": "node scripts/generateSubjects.js",
    "list-templates": "node scripts/generateSubjects.js --list-templates",
    "lint": "eslint src/ scripts/ tests/",
    "lint:fix": "eslint src/ scripts/ tests/ --fix",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:components": "vitest run tests/components",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:user-journeys": "vitest run tests/e2e/user-journeys",
    "test:e2e:accessibility": "vitest run tests/e2e/user-journeys/accessibility-journey.e2e.test.js",
    "test:performance": "vitest run tests/performance",
    "test:security": "vitest run tests/security",
    "test:accessibility": "vitest run tests/e2e/user-journeys/accessibility-journey.e2e.test.js",
    "test:visual": "vitest run tests/visual",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:unit": "vitest run tests/unit --coverage",
    "test:coverage:integration": "vitest run tests/integration --coverage",
    "test:coverage:all": "vitest run --coverage --reporter=json --outputFile=coverage-report.json",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:performance && npm run test:security",
    "test:ci": "npm run lint && npm run test:all && npm run test:coverage:all",
    "generate-test-report": "node scripts/generate-test-report.js",
    "serve": "python -m http.server 3000 -d src/pages",
    "build": "echo 'Static site - no build required'",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "keywords": ["education", "children", "games", "learning"],
  "private": true,
  "devDependencies": {
    "eslint": "^8.57.0",
    "@eslint/js": "^8.57.0",
    "vitest": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "jsdom": "^24.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "@vitest/coverage-v8": "^1.6.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "vitest related --run"
    ],
    "src/**/*.{html,css}": [
      "prettier --write --ignore-unknown"
    ]
  }
}