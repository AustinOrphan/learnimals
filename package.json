{
  "name": "learnimals",
  "version": "1.0.0",
  "description": "Educational web application featuring interactive games and activities for children",
  "type": "commonjs",
  "scripts": {
    "generate-subjects": "node scripts/generateSubjects.js",
    "list-templates": "node scripts/generateSubjects.js --list-templates",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/unit",
    "test:navigation": "vitest run tests/navigation",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["education", "children", "games", "learning"],
  "private": true,
  "devDependencies": {
    "eslint": "^8.57.0",
    "@eslint/js": "^8.57.0",
    "vitest": "^1.6.0",
    "jsdom": "^24.1.0",
    "@vitest/ui": "^1.6.0",
    "happy-dom": "^14.12.0"
  }
}