{
  "name": "learnimals",
  "version": "1.0.0",
  "description": "Educational web application featuring interactive games and activities for children",
  "type": "module",
  "scripts": {
    "generate-subjects": "node scripts/generateSubjects.js",
    "list-templates": "node scripts/generateSubjects.js --list-templates",
    "lint": "eslint src/ scripts/ tests/",
    "lint:fix": "eslint src/ scripts/ tests/ --fix",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md'",
    "prose:check": "vale '**/*.md'",
    "prose:readme": "vale README.md CLAUDE.md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:src": "prettier --write 'src/**/*.{js,html,css}'",
    "format:docs": "prettier --write '**/*.md'",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:components": "vitest run tests/components",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:user-journeys": "vitest run tests/e2e/user-journeys",
    "test:e2e:accessibility": "vitest run tests/e2e/user-journeys/accessibility-journey.e2e.test.js",
    "test:e2e:playwright": "playwright test",
    "test:e2e:playwright:ui": "playwright test --ui",
    "test:e2e:playwright:headed": "playwright test --headed",
    "test:e2e:playwright:ci": "playwright test --reporter=html",
    "test:performance": "vitest run tests/performance",
    "test:security": "vitest run tests/security",
    "test:accessibility": "vitest run tests/e2e/user-journeys/accessibility-journey.e2e.test.js",
    "test:visual": "vitest run tests/visual",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:unit": "vitest run tests/unit --coverage",
    "test:coverage:integration": "vitest run tests/integration --coverage",
    "test:coverage:all": "vitest run --coverage --reporter=json --outputFile=coverage-report.json",
    "coverage:report": "./scripts/coverage-report.sh",
    "coverage:open": "open coverage/index.html || xdg-open coverage/index.html || start coverage/index.html",
    "test:shard": "SHARD_COUNT=${SHARD_COUNT:-4} SHARD_INDEX=${SHARD_INDEX:-0} node scripts/test-sharding.js --pattern | xargs vitest run",
    "test:shard:report": "node scripts/test-sharding.js --report",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:performance && npm run test:security",
    "test:ci": "npm run lint && npm run test:all && npm run test:coverage:all",
    "generate-test-report": "node scripts/generate-test-report.js",
    "serve": "python -m http.server 3000 -d src/pages",
    "build": "echo 'Static site - no build required'",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "setup:hooks": "node scripts/setupGitHooks.js",
    "check:duplicates": "node scripts/checkDuplicates.js",
    "check:duplicates:fix": "node scripts/checkDuplicates.js --fix"
  },
  "keywords": [
    "education",
    "children",
    "games",
    "learning"
  ],
  "private": true,
  "devDependencies": {
    "@austinorphan/e2e-core": "file:../../e2e-core",
    "@eslint/js": "^8.57.0",
    "@playwright/test": "^1.58.1",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "jsdom": "^24.1.0",
    "lint-staged": "^15.2.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.0.0",
    "vitest": "^1.6.0",
    "wait-on": "^9.0.3"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "vitest related --run"
    ],
    "src/**/*.{html,css}": [
      "prettier --write --ignore-unknown"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ]
  }
}
