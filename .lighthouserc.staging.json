{
  "ci": {
    "collect": {
      "url": [
        "https://staging.learnimals.app/",
        "https://staging.learnimals.app/src/pages/about.html",
        "https://staging.learnimals.app/src/features/subjects/shared/math.html",
        "https://staging.learnimals.app/src/features/subjects/shared/science.html"
      ],
      "numberOfRuns": 5
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.8 }],
        "categories:pwa": ["warn", { "minScore": 0.8 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 3000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
